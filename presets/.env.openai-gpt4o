# Пресет: OpenAI GPT-4o (оптимизированная модель)
# Для использования: cp presets/.env.openai-gpt4o .env

LLM_PROVIDER=openai
LLM_URL=https://api.openai.com/v1/chat/completions
LLM_MODEL=gpt-4o
LLM_API_KEY=your-api-key-here
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
MAX_ITERATIONS=50
TIMEOUT=1200
ALLOWED_TOOL_RISK_LEVELS=read,write,dangerous
