# Пресет: LM Studio (локальные модели)
# Для использования: cp presets/.env.lm-studio .env
# Требуется запущенный LM Studio с включенным Local Server

LLM_PROVIDER=lm_studio
LLM_URL=http://127.0.0.1:1234/v1/chat/completions
LLM_MODEL=local-model
LLM_API_KEY=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
MAX_ITERATIONS=50
TIMEOUT=1200
ALLOWED_TOOL_RISK_LEVELS=read,write,dangerous
