# Пресет: Anthropic Claude
# Для использования: cp presets/.env.anthropic .env

LLM_PROVIDER=anthropic
LLM_URL=https://api.anthropic.com
LLM_MODEL=claude-3-opus-20240229
LLM_API_KEY=your-api-key-here
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
MAX_ITERATIONS=50
TIMEOUT=1200
ALLOWED_TOOL_RISK_LEVELS=read,write,dangerous
