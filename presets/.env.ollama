# Пресет: Ollama (локальные модели)
# Для использования: cp presets/.env.ollama .env
# Требуется запущенный Ollama: ollama serve

LLM_PROVIDER=ollama
LLM_URL=http://127.0.0.1:11434/v1/chat/completions
LLM_MODEL=llama3
LLM_API_KEY=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
MAX_ITERATIONS=50
TIMEOUT=1200
ALLOWED_TOOL_RISK_LEVELS=read,write,dangerous
